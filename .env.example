NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Mapbox Search Box API — token público (pk.) con URL allowlist en el dashboard.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_public_token

# Anthropic API — usado por el botón "IA" en admin/services para traducir contenido ES → EN/PT/FR/CA.
ANTHROPIC_API_KEY=your_anthropic_api_key
# Opcional. Default 'claude-sonnet-4-6' si no se setea.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Formulario "Haznos una sugerencia" de /servicios (envío por email
# vía Resend). Sin estas 3, el form muestra un error claro al enviar
# (no crashea). El FROM debe ser un dominio verificado en Resend.
RESEND_API_KEY=your_resend_api_key
SERVICE_SUGGESTIONS_FROM_EMAIL=sugerencias@tudominio.com
SERVICE_SUGGESTIONS_TO_EMAIL=destino@tudominio.com
